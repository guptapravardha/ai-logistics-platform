# =========================================
# LogiFlow — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to version control
# =========================================

# ─── Server ───────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ─── MongoDB ──────────────────────────────
# Atlas: mongodb+srv://user:password@cluster.mongodb.net/logiflow
# Local: mongodb://localhost:27017/logiflow
MONGODB_URI=mongodb://localhost:27017/logiflow

# ─── JWT ──────────────────────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_64_CHARS
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_STRONG_SECRET
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── Email (Nodemailer) ───────────────────
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password
EMAIL_FROM=LogiFlow <noreply@logiflow.in>

# ─── File Uploads ─────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,webp,doc,docx,xls,xlsx

# ─── Web Push Notifications ───────────────
# Generate: node -e "const wp=require('web-push'); const keys=wp.generateVAPIDKeys(); console.log(keys);"
VAPID_PUBLIC_KEY=REPLACE_WITH_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=REPLACE_WITH_VAPID_PRIVATE_KEY
VAPID_SUBJECT=mailto:admin@logiflow.in

# ─── Admin Account (auto-created on first run) ─
ADMIN_EMAIL=admin@logiflow.in
ADMIN_PASSWORD=Admin@123456
ADMIN_NAME=Super Admin

# ─── Rate Limiting ────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# ─── AI Services (optional, for Phase 8) ──
OPENAI_API_KEY=
GOOGLE_MAPS_API_KEY=
ANTHROPIC_API_KEY=

# ─── SMS (optional) ───────────────────────
MSG91_AUTH_KEY=
MSG91_SENDER_ID=LGFLOW

# ─── Storage (optional — S3 / Cloudinary) ─
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=

# ─── Logging ──────────────────────────────
LOG_LEVEL=debug
LOG_FILE=./logs/app.log
